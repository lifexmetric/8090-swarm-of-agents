{
  "name": "document-verification-service",
  "title": "Document Verification Service",
  "domain": "Customer And CRM",
  "port": 8122,
  "endpoint": "/v1/documents/verification",
  "region": "global",
  "dependencies": [
    {
      "name": "audit-log-service",
      "env": "AUDIT_LOG_SERVICE_URL",
      "url": "http://audit-log-service:8174"
