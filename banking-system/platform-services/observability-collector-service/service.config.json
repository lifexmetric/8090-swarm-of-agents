{
  "name": "observability-collector-service",
  "title": "Observability Collector Service",
  "domain": "Platform Services",
  "port": 8175,
  "endpoint": "/v1/observability/signals",
  "region": "global",
  "dependencies": [
    {
      "name": "event-warehouse-service",
      "env": "EVENT_WAREHOUSE_SERVICE_URL",
      "url": "http://event-warehouse-service:8161"
    }
  ],
  "topicsProduced": [
    "observability.signal.received"
  ],
  "topicsConsumed": [
    "mesh.route.changed"
  ],
  "dataStores": [
    "redis://redis:6379",
    "kafka://kafka:29092"
  ]
}
