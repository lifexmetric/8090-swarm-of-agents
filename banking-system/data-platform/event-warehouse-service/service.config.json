{
  "name": "event-warehouse-service",
  "title": "Event Warehouse Service",
  "domain": "Data And Analytics",
  "port": 8161,
  "endpoint": "/v1/warehouse/events",
  "region": "global",
  "dependencies": [
    {
      "name": "data-lake-ingestion-service",
