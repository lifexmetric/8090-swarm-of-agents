{
  "name": "emea-routing-service",
  "title": "Emea Routing Service",
  "domain": "Regionalization",
  "port": 8181,
  "endpoint": "/v1/regions/emea/routes",
  "region": "emea",
  "dependencies": [
    {
      "name": "sepa-rail-service",
      "env": "SEPA_RAIL_SERVICE_URL",
      "url": "http://sepa-rail-service:8141"
    },
    {
      "name": "sanctions-screening-service",
      "env": "SANCTIONS_SCREENING_SERVICE_URL",
      "url": "http://sanctions-screening-service:8151"
    },
    {
      "name": "swift-rail-service",
      "url": "http://mock-swift-rail:9999",
      "env": "SWIFT_RAIL_URL"
    }
  ],
  "topicsProduced": [
    "region.emea.routed"
  ],
  "topicsConsumed": [
    "partner.request.received"
  ],
  "dataStores": [
    "redis://redis:6379",
    "kafka://kafka:29092"
  ]
}
