{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/vercel-entry.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "100mb",
        "includeFiles": "api/src/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/vercel-entry" }
  ]
}
